#!/usr/bin/env bash
set -euo pipefail

# Resolve the lib/ directory relative to this script, even through symlinks
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/utils.sh"
source "$LIB_DIR/ui.sh"
source "$LIB_DIR/cmd_init.sh"
source "$LIB_DIR/cmd_pull.sh"
source "$LIB_DIR/cmd_run.sh"
source "$LIB_DIR/cmd_setenv.sh"
source "$LIB_DIR/cmd_clear_data.sh"
source "$LIB_DIR/cmd_update.sh"
source "$LIB_DIR/cmd_uninstall.sh"

bagitops_usage() {
  cat <<EOF
bagitops — GitOps deployment utility

Usage:
  bagitops init <project-name> <repo-url> [--ssh-key <path>]
  bagitops pull
  bagitops setenv <env-file> [<env-file> ...]
  bagitops run
  bagitops clear-data <service>
  bagitops update
  bagitops uninstall

Commands:
  init         Set project name, repo URL, and optional SSH key (required before pull)
  pull         Fetch latest snapshot, assemble image chunks, load into Docker
  setenv       Copy env file(s) to the location expected by containers (envs/)
  run          Validate env files, create volume dirs, start containers
  clear-data   Stop a service and wipe its bind-mount volume data
  update       Pull latest bagitops from the CLI repo
  uninstall    Remove bagitops and all its data
EOF
}

print_banner

[[ $# -ge 1 ]] || { bagitops_usage; exit 0; }

cmd="$1"; shift
case "$cmd" in
  init)          cmd_init "$@" ;;
  pull)          cmd_pull "$@" ;;
  setenv)        cmd_setenv "$@" ;;
  run)           cmd_run ;;
  clear-data)    cmd_clear_data "$@" ;;
  update)        cmd_update ;;
  uninstall)     cmd_uninstall ;;
  help|--help|-h) bagitops_usage ;;
  *) die "unknown command: $cmd (try 'bagitops help')" ;;
esac
